<div class="min-h-screen flex flex-col items-center justify-center text-center px-6 -mt-28">
  <!-- Hero -->
  <div class="max-w-2xl">
    <p class="text-zinc-400 text-sm sm:text-base mb-4 inline-flex items-center gap-2">
      Hey, <span class="text-orange-300 font-semibold"><%= current_user.name %></span>
      <%= button_to session_path,
            method: :delete,
            title: "Generate a new account",
            aria: { label: "Generate a new account" },
            class: "inline-flex items-center justify-center w-6 h-6 rounded-full text-zinc-400 hover:text-orange-300 hover:bg-zinc-800 transition-colors",
            form: { class: "inline" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
      <% end %>
    </p>

    <h1 class="text-6xl sm:text-7xl font-black tracking-tight text-white mb-2">
      Ring Roast
    </h1>

    <p class="text-lg sm:text-xl text-orange-300 font-semibold mb-8">
      It's like Spotify Wrapped, but instead of judging your music taste<br class="hidden sm:inline">
      - we judge your entire lifestyle.
    </p>

    <p class="text-zinc-400 text-base sm:text-lg leading-relaxed max-w-lg mx-auto mb-12">
      Connect your wearable, and we'll turn your sleep scores, step counts,
      and heart rate data into the roast you never asked for (but definitely deserve).
    </p>

    <!-- Connect Wearable CTA -->
    <div class="flex flex-col items-center gap-4">
      <button
        disabled
        class="inline-flex items-center gap-3 bg-orange-500 hover:bg-orange-400 disabled:opacity-60 disabled:cursor-not-allowed text-black font-bold text-lg px-8 py-4 rounded-full transition-colors shadow-lg shadow-orange-500/25"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        Connect Your Wearable
      </button>
      <span class="text-zinc-500 text-sm">Coming soon - wearable integration</span>
    </div>
  </div>

  <!-- Bottom tagline -->
  <p class="mt-20 text-zinc-600 text-sm tracking-wide uppercase">
    Your data. Your roast. No excuses.
  </p>
</div>
