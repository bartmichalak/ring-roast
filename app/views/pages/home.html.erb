<div class="min-h-screen flex flex-col items-center justify-center text-center px-6 -mt-28">
  <!-- Hero -->
  <div class="max-w-2xl">
    <p class="text-zinc-400 text-sm sm:text-base mb-4">
      Welcome, <span class="text-orange-300 font-semibold"><%= current_user.name %></span>
    </p>

    <h1 class="text-6xl sm:text-7xl font-black tracking-tight text-white mb-2">
      Ring Roast
    </h1>

    <p class="text-lg sm:text-xl text-orange-300 font-semibold mb-8">
      It's like Spotify Wrapped, but instead of judging your music taste<br class="hidden sm:inline">
      - we judge your entire lifestyle.
    </p>

    <p class="text-zinc-400 text-base sm:text-lg leading-relaxed max-w-lg mx-auto mb-12">
      Connect your wearable, and we'll turn your sleep scores, step counts,
      and heart rate data into the roast you never asked for (but definitely deserve).
    </p>

    <!-- Connect Wearable CTA -->
    <div class="flex flex-col items-center gap-4">
      <%= link_to connections_path,
            class: "inline-flex items-center gap-3 bg-orange-500 hover:bg-orange-400 text-black font-bold text-lg px-8 py-4 rounded-full transition-colors shadow-lg shadow-orange-500/25" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        Connect Your Wearable
      <% end %>

      <% if @connections.any? %>
        <div class="flex flex-wrap items-center justify-center gap-2 mt-2">
          <% @connections.each do |connection| %>
            <span class="inline-flex items-center gap-2 bg-green-500/15 text-green-300 border border-green-500/30 rounded-full px-3 py-1 text-sm font-medium">
              <span class="h-2 w-2 rounded-full bg-green-400"></span>
              <%= connection["provider"].to_s.capitalize %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Bottom tagline -->
  <p class="mt-20 text-zinc-600 text-sm tracking-wide uppercase">
    Your data. Your roast. No excuses.
  </p>
</div>
