<div data-card-navigation-target="card"
     class="absolute inset-0 flex flex-col items-center justify-center p-8 text-white transition-all duration-500"
     style="background-color: <%= color %>">
  <p class="text-lg uppercase tracking-widest opacity-70 mb-4">Your Longest Session</p>
  <h2 class="text-5xl sm:text-6xl font-black mb-2"><%= stats[:name] %></h2>
  <p class="text-3xl font-bold mb-6"><%= stats[:duration_formatted] %></p>
  <p class="text-xl opacity-80 mb-2"><%= stats[:date] %></p>
  <div class="flex gap-8 mt-4 opacity-70 text-lg">
    <% if stats[:calories_kcal] %>
      <span><%= stats[:calories_kcal].round %> kcal</span>
    <% end %>
    <% if stats[:avg_heart_rate_bpm] %>
      <span><%= stats[:avg_heart_rate_bpm] %> avg bpm</span>
    <% end %>
  </div>
</div>
