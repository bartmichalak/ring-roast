<div data-card-navigation-target="card"
     class="absolute inset-0 flex flex-col items-center justify-center p-8 text-white transition-all duration-500"
     style="background-color: <%= color %>">
  <% if roast.present? %>
    <p class="text-3xl sm:text-4xl font-black text-center max-w-2xl leading-snug mb-10">
      "<%= roast %>"
    </p>
  <% end %>
  <div class="opacity-70 text-center">
    <p class="text-2xl font-black mb-1"><%= stats[:name] %></p>
    <p class="text-lg"><%= stats[:duration_formatted] %> on <%= stats[:date] %></p>
    <div class="flex gap-6 mt-2 justify-center text-base">
      <% if stats[:calories_kcal] %>
        <span><%= stats[:calories_kcal].round %> kcal</span>
      <% end %>
      <% if stats[:avg_heart_rate_bpm] %>
        <span><%= stats[:avg_heart_rate_bpm] %> avg bpm</span>
      <% end %>
    </div>
  </div>
</div>
