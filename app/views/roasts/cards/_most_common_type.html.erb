<div data-card-navigation-target="card"
     class="absolute inset-0 flex flex-col items-center justify-center p-8 text-white transition-all duration-500"
     style="background-color: <%= color %>">
  <p class="text-lg uppercase tracking-widest opacity-70 mb-4">Your Go-To</p>
  <h2 class="text-6xl sm:text-7xl font-black mb-4"><%= stats[:type].titleize %></h2>
  <p class="text-2xl opacity-80"><%= stats[:count] %> times (<%= stats[:percentage] %>% of all workouts)</p>
</div>
