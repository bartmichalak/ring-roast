<div data-card-navigation-target="card"
     class="absolute inset-0 flex flex-col items-center justify-center p-8 text-white transition-all duration-500"
     style="background-color: <%= color %>">
  <p class="text-lg uppercase tracking-widest opacity-70 mb-8">By The Numbers</p>
  <div class="flex flex-col gap-8">
    <div class="text-center">
      <h2 class="text-7xl sm:text-8xl font-black"><%= number_with_delimiter(stats[:total_calories_kcal]) %></h2>
      <p class="text-2xl opacity-80">calories burned</p>
    </div>
    <div class="text-center">
      <h2 class="text-7xl sm:text-8xl font-black"><%= stats[:total_distance_km] %></h2>
      <p class="text-2xl opacity-80">km covered</p>
    </div>
    <% if stats[:avg_heart_rate_bpm] %>
      <div class="text-center">
        <h2 class="text-5xl font-black"><%= stats[:avg_heart_rate_bpm] %> bpm</h2>
        <p class="text-xl opacity-80">average heart rate</p>
      </div>
    <% end %>
  </div>
</div>
