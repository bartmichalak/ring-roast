<div data-card-navigation-target="card"
     class="absolute inset-0 flex flex-col items-center justify-center p-8 text-white transition-all duration-500"
     style="background-color: <%= color %>">
  <% if roast.present? %>
    <p class="text-3xl sm:text-4xl font-black text-center max-w-2xl leading-snug mb-10">
      "<%= roast %>"
    </p>
  <% end %>
  <div class="opacity-70 text-center">
    <div class="flex gap-8 justify-center flex-wrap">
      <div>
        <p class="text-3xl font-black"><%= number_with_delimiter(stats[:total_calories_kcal]) %></p>
        <p class="text-base">calories burned</p>
      </div>
      <div>
        <p class="text-3xl font-black"><%= stats[:total_distance_km] %></p>
        <p class="text-base">km covered</p>
      </div>
      <% if stats[:avg_heart_rate_bpm] %>
        <div>
          <p class="text-3xl font-black"><%= stats[:avg_heart_rate_bpm] %></p>
          <p class="text-base">avg bpm</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
